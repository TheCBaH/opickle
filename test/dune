; Per-module inline expect tests for the opickle library.

(library
 (name opickle_tests)
 (libraries opickle bytesrw)
 (inline_tests)
 (preprocess
  (pps ppx_expect)))

; Copy the pickle fixtures (generated by CPython, see
; modules/serde-pickle/test/data/generate.py) into the test build dir so the
; cram tests can feed them to pickle_dump.

(copy_files
 (files ../modules/serde-pickle/test/data/*.pickle))

(cram
 (deps
  %{bin:pickle_dump}
  genpickle.py
  (glob_files *.pickle)))
